<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
          xmlns:tools="http://schemas.android.com/tools">

    <!-- Always required -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Conditionally included via manifest placeholders set in app/build.gradle.
         tools:node="merge" keeps the permission, tools:node="remove" strips it
         from the final merged manifest so the AAB only declares what the user
         actually enabled. Required for Play Console policy compliance. -->
    <uses-permission android:name="com.android.vending.BILLING" tools:node="${billingNode}" />
    <uses-permission android:name="android.permission.VIBRATE" tools:node="${vibrateNode}" />

    <uses-permission android:name="android.permission.CAMERA" tools:node="${cameraNode}" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" tools:node="${microphoneNode}" />

    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" tools:node="${locationNode}" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" tools:node="${locationNode}" />

    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
                     android:maxSdkVersion="32" tools:node="${storageNode}" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
                     android:maxSdkVersion="29" tools:node="${storageNode}" />
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" tools:node="${mediaNode}" />
    <uses-permission android:name="android.permission.READ_MEDIA_VIDEO" tools:node="${mediaNode}" />
    <uses-permission android:name="android.permission.READ_MEDIA_AUDIO" tools:node="${mediaNode}" />

    <uses-permission android:name="android.permission.SEND_SMS" tools:node="${smsNode}" />
    <uses-permission android:name="android.permission.RECEIVE_SMS" tools:node="${smsNode}" />
    <uses-permission android:name="android.permission.READ_SMS" tools:node="${smsNode}" />

    <uses-permission android:name="android.permission.READ_CONTACTS" tools:node="${contactsNode}" />
    <uses-permission android:name="android.permission.WRITE_CONTACTS" tools:node="${contactsNode}" />

    <uses-permission android:name="android.permission.READ_PHONE_STATE" tools:node="${phoneNode}" />
    <uses-permission android:name="android.permission.CALL_PHONE" tools:node="${phoneNode}" />

    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" tools:node="${pushNode}" />

    <uses-permission android:name="android.permission.USE_BIOMETRIC" tools:node="${biometricNode}" />
    <uses-permission android:name="android.permission.USE_FINGERPRINT" tools:node="${biometricNode}" />

    <uses-permission android:name="android.permission.BLUETOOTH" android:maxSdkVersion="30" tools:node="${bluetoothNode}" />
    <uses-permission android:name="android.permission.BLUETOOTH_ADMIN" android:maxSdkVersion="30" tools:node="${bluetoothNode}" />
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" tools:node="${bluetoothNode}" />
    <uses-permission android:name="android.permission.BLUETOOTH_SCAN" tools:node="${bluetoothNode}" />

    <uses-permission android:name="android.permission.NFC" tools:node="${nfcNode}" />

    <uses-permission android:name="android.permission.READ_CALENDAR" tools:node="${calendarNode}" />
    <uses-permission android:name="android.permission.WRITE_CALENDAR" tools:node="${calendarNode}" />

    <uses-permission android:name="android.permission.WAKE_LOCK" tools:node="${wakeLockNode}" />

    <uses-feature android:name="android.hardware.camera" android:required="false" />
    <uses-feature android:name="android.hardware.location" android:required="false" />
    <uses-feature android:name="android.hardware.bluetooth" android:required="false" />
    <uses-feature android:name="android.hardware.nfc" android:required="false" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.AABForge"
        android:usesCleartextTraffic="true"
        tools:targetApi="33">
        <activity
            android:name=".MainActivity"
            android:configChanges="keyboardHidden|orientation|screenSize|uiMode"
            android:exported="true"
            android:theme="@style/Theme.AABForge.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>
